{
    "all": {
      "agents": {
        "searcher": {
          "name": "searcher",
          "localized_name": "搜索助手",
          "desc": "负责搜索和收集相关信息，了解用户需求并进行研究分析",
          "desc_for_llm": [
            "负责联网搜索和中国移动内部搜索",
            "联网搜索使用搜索引擎从互联网收集信息。例如查看天气、新闻等资讯。 ",
            "内部搜索可以搜索内部公文、公告、新闻、用户的已办、通讯录、MOA应用程序信息。",
            "任务示例：明天北京的天气如何？",
            "任务示例：找一下数智化部的张三"
          ],
          "is_optional": true,
          "agent_type": "inner"
        },
        "reporter": {
          "name": "reporter",
          "localized_name": "报告助手",
          "desc": "负责撰写报告。",
          "desc_for_llm": [
            "报告助手。负责撰写报告。**该智能体成本很高，只有用户明确需要时，才能调用**",
            "任务示例：用户需要一个关于中国移动供应链的报告，请撰写一个报告。"
          ],
          "is_optional": true,
          "agent_type": "inner"
        },
        "email": {
          "name": "email",
          "localized_name": "邮件助手",
          "desc": "负责管理用户邮箱。",
          "desc_for_llm": [
            "邮件助手。发送邮件，可以帮助用户发送邮件给指定用户",
            "**邮件助手内部有通讯录查询功能，可以查询收件人，不需要单独调用搜索**",
            "任务示例：发送邮件给张三",
            "**邮箱助手支持多轮对话**，可以由邮箱助手获取具体邮件信息。",
            "如果用户没有表达通知某人、发邮件意图，**不要调用**"
          ],
          "is_optional": true,
          "agent_type": "inner"
        },
        "reminder": {
          "name": "reminder",
          "localized_name": "提醒助手",
          "desc": "提醒助手",
          "desc_for_llm": [
            "提醒助手，可以查询提醒、创建提醒、删除提醒、修改提醒。",
            "任务示例:查询明天的提醒",
            "任务示例：**查看我的安排**"
          ],
          "is_optional": true,
          "agent_type": "inner"
        },
        "schedule": {
          "name": "schedule",
          "localized_name": "日程助手",
          "desc": "日程助手，可以帮助用户查询、创建、修改日程。",
          "desc_for_llm": [
            "日程助手，可以帮助用户查询、创建、修改日程。",
            "支持查询指定时间范围内的日程安排；创建新的日程（包括会议安排）；修改已有日程；删除日程。",
            "日程助手内部可向用户追问更多细节。"
          ],
          "is_optional": true,
          "agent_type": "outer"
        },
        "ppt": {
          "name": "ppt",
          "localized_name": "PPT助手",
          "desc": "ppt助手，可以帮助用户创建PPT。",
          "desc_for_llm": [
            "ppt助手，可以帮助用户创建PPT。",
            "根据用户主题与要求生成结构化PPT内容并可落地到文件。任务示例：创建一个大模型发展的PPT。",
            "**用户明确需要做PPT时才调用该智能体。**"
          ],
          "is_optional": true,
          "agent_type": "outer"
        },
        "todo": {
          "name": "todo",
          "localized_name": "待办助手",
          "desc": "待办助手，可支持待办信息查询。",
          "desc_for_llm": [
            "待办助手，可支持待办信息查询。",
            "支持查询：全部待办、公文待办、合同待办、采购待办、人力待办、报账待办、其他待办、逾期待办、重要待办。"
          ],
          "is_optional": true,
          "agent_type": "outer"
        },
        "travel": {
          "name": "travel",
          "localized_name": "出行助手",
          "desc": "出行助手，可以差旅申请、申请用车。",
          "desc_for_llm": [
            "出行助手，可以差旅申请、申请用车。",
            "示例：我要用车，从北京南站出发；我要出差"
