LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
DATABASE_PATH=meowone.db

LOOP_MAX_ROUNDS=16
# Tool rounds per user message (model may call tools → observe → call again)
LOOP_MAX_TOOL_PHASES=8
LOOP_TIMEOUT_SECONDS=120
TOOL_TIMEOUT_SECONDS=30

# Skills / context / MCP live under repository `.meowone/` by default
MEOWONE_CONFIG_DIR=.meowone
MAX_CONTEXT_CHARS=24000
MAX_SKILLS_CHARS=8000

# Optional: override agents file (default: `.meowone/agents.yaml`)
# AGENTS_CONFIG_PATH=

# Optional channel capability policy file: `.meowone/channels.yaml`
# (loaded automatically via MEOWONE_CONFIG_DIR)

# Workspace root for file + bash tools (default: repository root)
# WORKSPACE_ROOT=

# Bash tool (disabled by default)
MEOWONE_ALLOW_BASH=0
