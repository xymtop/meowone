# ============================================================
# MeowOne 环境变量配置文件
# 复制为 .env 后修改对应值即可
# ============================================================

# --- LLM 配置（必须填）---
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- 后端配置 ---
# 数据库路径（容器内无需修改，数据通过 volume 持久化）
DATABASE_PATH=/app/data/meowone.db
# Agent 循环最大轮次
LOOP_MAX_ROUNDS=10
# Agent 循环超时时间（秒）
LOOP_TIMEOUT_SECONDS=120
