# ============================================================
# MeowOne 生产环境变量配置文件
# 上线前必须修改以下敏感值
# ============================================================

# --- LLM 配置（必须填，使用生产级 API）---
LLM_API_KEY=sk-prod-replace-this-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- 后端配置 ---
DATABASE_PATH=/app/data/meowone.db
LOOP_MAX_ROUNDS=15
LOOP_TIMEOUT_SECONDS=180
TOOL_TIMEOUT_SECONDS=60

# 上下文限制
MAX_CONTEXT_CHARS=32000
MAX_SKILLS_CHARS=16000

# 安全配置：生产环境禁止 Bash 工具
MEOWONE_ALLOW_BASH=0
MEOWONE_CONFIG_DIR=/app/.meowone

# --- 生产特有配置 ---
LOG_LEVEL=info
CORS_ORIGINS=https://your-domain.com

# --- 前端配置（Docker 网络内部）---
NEXT_PUBLIC_API_URL=http://backend:8000
